{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LOTOFA-CORE normalized Lotofacil draw record",
  "type": "object",
  "required": [
    "concurso",
    "data_sorteio",
    "n01",
    "n02",
    "n03",
    "n04",
    "n05",
    "n06",
    "n07",
    "n08",
    "n09",
    "n10",
    "n11",
    "n12",
    "n13",
    "n14",
    "n15",
    "h_set",
    "e_set"
  ],
  "properties": {
    "concurso": {
      "type": "integer",
      "description": "Numero oficial do concurso"
    },
    "data_sorteio": {
      "type": "string",
      "format": "date",
      "description": "Data ISO yyyy-mm-dd"
    },
    "n01": {
      "type": "integer",
      "minimum": 1,
      "maximum": 25
    },
    "n02": {
      "type": "integer",
      "minimum": 1,
      "maximum": 25
    },
    "n03": {
      "type": "integer",
      "minimum": 1,
      "maximum": 25
    },
    "n04": {
      "type": "integer",
      "minimum": 1,
      "maximum": 25
    },
    "n05": {
      "type": "integer",
      "minimum": 1,
      "maximum": 25
    },
    "n06": {
      "type": "integer",
      "minimum": 1,
      "maximum": 25
    },
    "n07": {
      "type": "integer",
      "minimum": 1,
      "maximum": 25
    },
    "n08": {
      "type": "integer",
      "minimum": 1,
      "maximum": 25
    },
    "n09": {
      "type": "integer",
      "minimum": 1,
      "maximum": 25
    },
    "n10": {
      "type": "integer",
      "minimum": 1,
      "maximum": 25
    },
    "n11": {
      "type": "integer",
      "minimum": 1,
      "maximum": 25
    },
    "n12": {
      "type": "integer",
      "minimum": 1,
      "maximum": 25
    },
    "n13": {
      "type": "integer",
      "minimum": 1,
      "maximum": 25
    },
    "n14": {
      "type": "integer",
      "minimum": 1,
      "maximum": 25
    },
    "n15": {
      "type": "integer",
      "minimum": 1,
      "maximum": 25
    },
    "h_set": {
      "type": "string",
      "description": "15 dezenas sorteadas, zero padded, separadas por espaco"
    },
    "e_set": {
      "type": "string",
      "description": "10 dezenas nao sorteadas/complemento E, zero padded, separadas por espaco"
    },
    "h_mask_25bit": {
      "type": "integer",
      "description": "Mascara bitset com bits 0..24 representando dezenas 1..25"
    },
    "e_mask_25bit": {
      "type": "integer",
      "description": "Mascara bitset do complemento E"
    },
    "soma": {
      "type": "integer"
    },
    "qtd_pares": {
      "type": "integer"
    },
    "qtd_impares": {
      "type": "integer"
    },
    "qtd_moldura": {
      "type": "integer"
    },
    "qtd_miolo": {
      "type": "integer"
    }
  }
}